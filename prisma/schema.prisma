generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id                  String        @id @default(cuid())
  patientId           String        @unique
  philHealthPIN       String?       @unique
  nationalId          String?       @unique
  seniorId            String?       @unique
  pwdId               String?       @unique
  firstName           String
  middleName          String?
  lastName            String
  extensionName       String?
  dateOfBirth         DateTime
  gender              Gender
  civilStatus         String?
  address             String?
  barangay            String?
  city                String?
  province            String?
  zipCode             String?
  mobileNumber        String?
  email               String?
  bloodType           String?
  allergies           String?
  status              PatientStatus @default(OUTPATIENT)
  dpaConsentTimestamp DateTime?
  registeredByUserId  String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  admissions          Admission[]

  @@index([firstName, lastName])
  @@index([patientId])
}

model Admission {
  id                 String          @id @default(cuid())
  admissionId        String          @unique
  patientId          String
  type               PatientStatus   @default(ER)
  status             AdmissionStatus @default(ACTIVE)
  triageLevel        TriageLevel?
  chiefComplaint     String
  admittingDiagnosis String?
  finalDiagnosis     String?
  primaryCaseRateId  String?
  roomNumber         String?
  bedNumber          String?
  admittedAt         DateTime        @default(now())
  dischargedAt       DateTime?
  admittedByUserId   String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  bedId              String?         @unique
  bed                Bed?            @relation("CurrentBed", fields: [bedId], references: [id])
  patient            Patient         @relation(fields: [patientId], references: [id])
  primaryCaseRate    CaseRate?       @relation("PrimaryCaseRate", fields: [primaryCaseRateId], references: [id])
  doctorOrders       DoctorOrder[]
  invoice            Invoice?
  labOrders          LabOrder[]
  nursingNotes       NursingNote[]
  vitals             Vitals[]

  @@index([patientId])
  @@index([status])
}

model Ward {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rooms       Room[]
}

model Room {
  id        String   @id @default(cuid())
  name      String
  wardId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  beds      Bed[]
  ward      Ward     @relation(fields: [wardId], references: [id])

  @@unique([wardId, name])
}

model Bed {
  id               String     @id @default(cuid())
  name             String
  status           BedStatus  @default(VACANT)
  roomId           String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  currentAdmission Admission? @relation("CurrentBed")
  room             Room       @relation(fields: [roomId], references: [id])

  @@unique([roomId, name])
}

model Medication {
  id           String                 @id @default(cuid())
  code         String                 @unique
  name         String
  genericName  String?
  form         String
  strength     String?
  unit         String
  price        Decimal                @db.Decimal(12, 2)
  stock        Int                    @default(0)
  reorderLevel Int                    @default(10)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  transactions InventoryTransaction[]
  batches      StockBatch[]
}

model StockBatch {
  id                String                 @id @default(cuid())
  medicationId      String
  batchNumber       String
  expiryDate        DateTime
  initialQuantity   Int
  remainingQuantity Int
  status            String                 @default("ACTIVE")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  transactions      InventoryTransaction[]
  medication        Medication             @relation(fields: [medicationId], references: [id])

  @@index([medicationId])
  @@index([expiryDate])
}

model InventoryTransaction {
  id               String      @id @default(cuid())
  medicationId     String
  type             String
  quantity         Int
  batchNumber      String?
  expiryDate       DateTime?
  referenceId      String?
  createdAt        DateTime    @default(now())
  recordedByUserId String?
  batchId          String?
  batch            StockBatch? @relation(fields: [batchId], references: [id])
  medication       Medication  @relation(fields: [medicationId], references: [id])
}

model LabTest {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  category  String
  price     Decimal    @db.Decimal(12, 2)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  orders    LabOrder[]
}

model LabOrder {
  id              String    @id @default(cuid())
  orderNumber     String    @unique
  admissionId     String
  testId          String
  status          String    @default("PENDING")
  result          String?
  orderedByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  admission       Admission @relation(fields: [admissionId], references: [id])
  test            LabTest   @relation(fields: [testId], references: [id])

  @@index([admissionId])
}

model NursingNote {
  id               String    @id @default(cuid())
  admissionId      String
  note             String
  type             String    @default("PROGRESS")
  recordedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  admission        Admission @relation(fields: [admissionId], references: [id])

  @@index([admissionId])
}

model DoctorOrder {
  id           String    @id @default(cuid())
  admissionId  String
  type         String
  description  String
  instructions String?
  status       String    @default("PENDING")
  orderedById  String
  executedById String?
  executedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  admission    Admission @relation(fields: [admissionId], references: [id])
  executedBy   Staff?    @relation("ExecutedBy", fields: [executedById], references: [id])
  orderedBy    Staff     @relation("OrderedBy", fields: [orderedById], references: [id])

  @@index([admissionId])
}

model CaseRate {
  id          String      @id @default(cuid())
  code        String      @unique
  description String
  itemType    String
  hciAmount   Decimal     @db.Decimal(12, 2)
  hcpAmount   Decimal     @db.Decimal(12, 2)
  totalAmount Decimal     @db.Decimal(12, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  admissions  Admission[] @relation("PrimaryCaseRate")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      StaffRole @default(NURSE)
  staffId   String?   @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  staff     Staff?    @relation(fields: [staffId], references: [id])
}

model Department {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  staff       Staff[]
}

model Staff {
  id               String        @id @default(cuid())
  staffId          String        @unique
  firstName        String
  lastName         String
  role             StaffRole
  specialization   String?
  departmentId     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  ordersExecuted   DoctorOrder[] @relation("ExecutedBy")
  ordersIssued     DoctorOrder[] @relation("OrderedBy")
  professionalFees InvoiceItem[]
  department       Department?   @relation(fields: [departmentId], references: [id])
  user             User?
}

model Invoice {
  id               String           @id @default(cuid())
  invoiceNumber    String           @unique
  admissionId      String           @unique
  status           InvoiceStatus    @default(DRAFT)
  discountType     DiscountType     @default(NONE)
  grossAmount      Decimal          @default(0) @db.Decimal(12, 2)
  vatAmount        Decimal          @default(0) @db.Decimal(12, 2)
  discountAmount   Decimal          @default(0) @db.Decimal(12, 2)
  philHealthAmount Decimal          @default(0) @db.Decimal(12, 2)
  hmoAmount        Decimal          @default(0) @db.Decimal(12, 2)
  netAmount        Decimal          @default(0) @db.Decimal(12, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  balance          Decimal          @default(0) @db.Decimal(12, 2)
  paidAmount       Decimal          @default(0) @db.Decimal(12, 2)
  admission        Admission        @relation(fields: [admissionId], references: [id])
  items            InvoiceItem[]
  payments         Payment[]
  philHealthClaim  PhilHealthClaim?

  @@index([admissionId])
}

model Payment {
  id               String   @id @default(cuid())
  invoiceId        String
  amount           Decimal  @db.Decimal(12, 2)
  paymentMethod    String
  referenceNumber  String?
  recordedByUserId String?
  createdAt        DateTime @default(now())
  invoice          Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model PhilHealthClaim {
  id                 String    @id @default(cuid())
  invoiceId          String    @unique
  claimSeriesLnk     String?
  status             String    @default("DRAFT")
  totalAmountClaimed Decimal   @db.Decimal(12, 2)
  amountApproved     Decimal?  @db.Decimal(12, 2)
  dateSubmitted      DateTime?
  dateProcessed      DateTime?
  remarks            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  invoice            Invoice   @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  category    String
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  isVatable   Boolean  @default(true)
  staffId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  staff       Staff?   @relation(fields: [staffId], references: [id])

  @@index([invoiceId])
}

model Vitals {
  id               String    @id @default(cuid())
  admissionId      String
  bpSystolic       Int?
  bpDiastolic      Int?
  temperature      Float?
  pulseRate        Int?
  respiratoryRate  Int?
  o2Saturation     Int?
  weight           Float?
  height           Float?
  recordedAt       DateTime  @default(now())
  recordedByUserId String?
  admission        Admission @relation(fields: [admissionId], references: [id])

  @@index([admissionId])
}

enum PatientStatus {
  OUTPATIENT
  INPATIENT
  ER
  OBSERVATION
  RECOVERED
  DECEASED
}

enum TriageLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
  LEVEL_5
}

enum AdmissionStatus {
  ACTIVE
  DISCHARGED
  CANCELLED
  TRANSFERRED
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum DiscountType {
  NONE
  SENIOR_CITIZEN
  PWD
  HMO
  CHARITY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BedStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
  CLEANING
}

enum StaffRole {
  ADMIN
  DOCTOR
  NURSE
  BILLING
  PHARMACY
  LABORATORY
}
