generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id               String             @id @default(cuid())
  patientId        String             @unique
  philHealthId     String?            @unique
  nationalId       String?            @unique
  seniorCitizenId  String?            @unique
  pwdId            String?            @unique
  firstName        String
  middleName       String?
  lastName         String
  dateOfBirth      DateTime
  gender           Gender
  status           PatientStatus      @default(OUTPATIENT)
  civilStatus      String?
  nationality      String             @default("Filipino")
  religion         String?
  occupation       String?
  address          String?
  barangay         String?
  city             String?
  province         String?
  zipCode          String?
  mobileNumber     String?
  email            String?
  bloodType        String?
  allergies        String?
  emergencyContact String?
  emergencyNumber  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  admissions       Admission[]
  appointments     Appointment[]
  assignedBed      Bed?               @relation("PatientBed")
  billingRecords   BillingRecord[]
  clinicalNotes    ClinicalNote[]
  labRequests      LabRequest[]
  prescriptions    Prescription[]
  radRequests      RadiologyRequest[]
}

model Admission {
  id                   String               @id @default(cuid())
  patientId            String
  admittedAt           DateTime             @default(now())
  dischargedAt         DateTime?
  admittingDiagnosis   String
  finalDiagnosis       String?
  homeMedications      String?
  followUpInstructions String?
  roomNumber           String
  ward                 String?
  isPhilHealthMember   Boolean              @default(false)
  philHealthPIN        String?
  dpaConsentTimestamp  DateTime?
  status               AdmissionStatus      @default(ADMITTED)
  department           String               @default("ADMITTING") // ER or ADMITTING
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  admissionSource      String               @default("Walk-in")
  admissionType        AdmissionType        @default(ROUTINE)
  guarantorName        String?
  guarantorPhone       String?
  guarantorRelation    String?
  patient              Patient              @relation(fields: [patientId], references: [id])
  physicians           AdmissionPhysician[]
  bed                  Bed?
  billingRecords       BillingRecord[]
}

model AdmissionPhysician {
  id          String    @id @default(cuid())
  admissionId String
  physicianId String
  role        String    @default("ATTENDING")
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  admission   Admission @relation(fields: [admissionId], references: [id])
  physician   User      @relation(fields: [physicianId], references: [id])

  @@unique([admissionId, physicianId])
}

model LabRequest {
  id          String    @id @default(cuid())
  patientId   String
  testName    String
  category    String
  doctorName  String
  status      String    @default("PENDING")
  results     String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  patient     Patient   @relation(fields: [patientId], references: [id])
}

model RadiologyRequest {
  id            String    @id @default(cuid())
  patientId     String
  procedureName String
  type          String
  doctorName    String
  status        String    @default("PENDING")
  findings      String?
  impression    String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  patient       Patient   @relation(fields: [patientId], references: [id])
}

model InventoryItem {
  id            String             @id @default(cuid())
  name          String
  genericName   String?
  sku           String             @unique
  category      String
  unit          String
  currentStock  Int                @default(0)
  minStockLevel Int                @default(10)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  transactions  StockTransaction[]
}

model StockTransaction {
  id          String        @id @default(cuid())
  itemId      String
  type        String
  quantity    Int
  batchNumber String?
  expiryDate  DateTime?
  referenceId String?
  notes       String?
  createdAt   DateTime      @default(now())
  item        InventoryItem @relation(fields: [itemId], references: [id])
}

model Appointment {
  id              String   @id @default(cuid())
  patientId       String
  doctorName      String
  appointmentDate DateTime
  reason          String?
  status          String   @default("SCHEDULED")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  patient         Patient  @relation(fields: [patientId], references: [id])
}

model BillingRecord {
  id              String          @id @default(cuid())
  patientId       String
  description     String?
  totalAmount     Decimal         @default(0) @db.Decimal(10, 2)
  philHealthShare Decimal         @default(0) @db.Decimal(10, 2)
  hmoShare        Decimal         @default(0) @db.Decimal(10, 2)
  discountTotal   Decimal         @default(0) @db.Decimal(10, 2)
  patientShare    Decimal         @default(0) @db.Decimal(10, 2)
  status          String          @default("UNPAID")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  admissionId     String?
  balanceAmount   Decimal         @default(0) @db.Decimal(10, 2)
  caseRateAmount  Decimal         @default(0) @db.Decimal(10, 2)
  grossAmount     Decimal         @default(0) @db.Decimal(10, 2)
  paidAmount      Decimal         @default(0) @db.Decimal(10, 2)
  vatExemptAmount Decimal         @default(0) @db.Decimal(10, 2)
  items           BillingItem[]
  admission       Admission?      @relation(fields: [admissionId], references: [id])
  patient         Patient         @relation(fields: [patientId], references: [id])
  payments        Payment[]
  promissoryNote  PromissoryNote?
}

model Payment {
  id              String        @id @default(cuid())
  billingRecordId String
  amount          Decimal       @db.Decimal(10, 2)
  method          String
  referenceNumber String?
  collectedBy     String?
  createdAt       DateTime      @default(now())
  billingRecord   BillingRecord @relation(fields: [billingRecordId], references: [id])
}

model PromissoryNote {
  id               String        @id @default(cuid())
  billingRecordId  String        @unique
  totalAmount      Decimal       @db.Decimal(10, 2)
  initialPayment   Decimal       @default(0) @db.Decimal(10, 2)
  remainingBalance Decimal       @db.Decimal(10, 2)
  dueDate          DateTime
  reason           String?
  guarantorName    String?
  guarantorContact String?
  status           String        @default("ACTIVE")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  billingRecord    BillingRecord @relation(fields: [billingRecordId], references: [id])
}

model BillingItem {
  id              String        @id @default(cuid())
  billingRecordId String
  serviceName     String
  category        String?
  quantity        Int           @default(1)
  unitPrice       Decimal       @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  isVatable       Boolean       @default(true)
  billingRecord   BillingRecord @relation(fields: [billingRecordId], references: [id])
}

model Service {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  basePrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isVatable Boolean  @default(true)
}

model ClinicalNote {
  id               String   @id @default(cuid())
  patientId        String
  doctorName       String
  subjective       String?
  objective        String?
  assessment       String?
  plan             String?
  diagnosis        String?
  icd10Code        String?
  bloodPressure    String?
  temperature      Decimal? @db.Decimal(4, 1)
  heartRate        Int?
  respiratoryRate  Int?
  oxygenSaturation Int?
  weight           Decimal? @db.Decimal(5, 2)
  height           Decimal? @db.Decimal(5, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  patient          Patient  @relation(fields: [patientId], references: [id])
}

model Prescription {
  id         String             @id @default(cuid())
  patientId  String
  doctorName String
  notes      String?
  status     String             @default("ACTIVE")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  patient    Patient            @relation(fields: [patientId], references: [id])
  items      PrescriptionItem[]
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  medicationName String
  dosage         String
  frequency      String
  duration       String?
  instructions   String?
  createdAt      DateTime     @default(now())
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
}

model Medication {
  id          String   @id @default(cuid())
  name        String   @unique
  genericName String
  form        String
  strength    String
  category    String?
  createdAt   DateTime @default(now())
  basePrice   Decimal? @db.Decimal(10, 2)
  isVatable   Boolean  @default(true)
}

model Room {
  id         String   @id @default(cuid())
  roomNumber String   @unique
  type       String
  floor      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  beds       Bed[]
}

model Bed {
  id          String     @id @default(cuid())
  bedNumber   String
  roomId      String
  status      String     @default("AVAILABLE")
  patientId   String?    @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  admissionId String?    @unique
  admission   Admission? @relation(fields: [admissionId], references: [id])
  patient     Patient?   @relation("PatientBed", fields: [patientId], references: [id])
  room        Room       @relation(fields: [roomId], references: [id])
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  licenseNumber       String?              @unique
  specialization      String?
  status              String               @default("ACTIVE")
  lastLogin           DateTime?
  roleId              String
  primaryDepartmentId String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  admissions          AdmissionPhysician[]
  performedActions    AuditLog[]           @relation("PerformedActions")
  auditLogs           AuditLog[]           @relation("UserAuditLogs")
  primaryDepartment   Department?          @relation("PrimaryDepartment", fields: [primaryDepartmentId], references: [id])
  role                Role                 @relation(fields: [roleId], references: [id])
  departments         UserDepartment[]
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("PermissionToRole")
}

model Department {
  id           String           @id @default(cuid())
  name         String           @unique
  description  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  primaryUsers User[]           @relation("PrimaryDepartment")
  users        UserDepartment[]
}

model UserDepartment {
  userId       String
  departmentId String
  isHead       Boolean    @default(false)
  department   Department @relation(fields: [departmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@id([userId, departmentId])
}

model AuditLog {
  id            String   @id @default(cuid())
  action        String
  table         String?
  recordId      String?
  changes       Json?
  userId        String?
  performedById String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
  performedBy   User?    @relation("PerformedActions", fields: [performedById], references: [id])
  user          User?    @relation("UserAuditLogs", fields: [userId], references: [id])
}

enum PatientStatus {
  INPATIENT
  OUTPATIENT
  EMERGENCY
  OBSERVATION
  RECOVERED
  DECEASED
}

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
  PENDING_BILLING
  CANCELLED
  ER_RELEASED
  TRANSFERRED
}

enum AdmissionType {
  ROUTINE
  EMERGENCY
  URGENT
  MATERNITY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}
