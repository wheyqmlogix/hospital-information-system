generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PatientStatus {
  OUTPATIENT
  INPATIENT
  ER
  OBSERVATION
  RECOVERED
  DECEASED
}

enum TriageLevel {
  LEVEL_1 // Resuscitation (Immediate)
  LEVEL_2 // Emergent
  LEVEL_3 // Urgent
  LEVEL_4 // Less Urgent
  LEVEL_5 // Non-Urgent
}

enum AdmissionStatus {
  ACTIVE
  DISCHARGED
  CANCELLED
  TRANSFERRED
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum DiscountType {
  NONE
  SENIOR_CITIZEN
  PWD
  HMO
  CHARITY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Patient {
  id               String         @id @default(cuid())
  patientId        String         @unique // PT-YYYY-XXXXX
  
  // Primary Identifiers (PH)
  philHealthPIN    String?        @unique
  nationalId       String?        @unique
  seniorId         String?        @unique
  pwdId            String?        @unique

  // Demographics
  firstName        String
  middleName       String?        // Highly important in PH context
  lastName         String
  extensionName    String?        // e.g., Jr., III
  dateOfBirth      DateTime
  gender           Gender
  civilStatus      String?        // SINGLE, MARRIED, WIDOWED, SEPARATED
  
  // PH Geographic Data
  address          String?
  barangay         String?
  city             String?
  province         String?
  zipCode          String?
  
  // Contact & Clinical
  mobileNumber     String?
  email            String?
  bloodType        String?
  allergies        String?
  
  // Regulatory & Audit
  status           PatientStatus  @default(OUTPATIENT)
  dpaConsentTimestamp DateTime?
  registeredByUserId String?
  
  // Relations
  admissions       Admission[]
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([firstName, lastName])
  @@index([patientId])
}

model Admission {
  id               String           @id @default(cuid())
  admissionId      String           @unique // ADM-YYYY-XXXXX

  patient          Patient          @relation(fields: [patientId], references: [id])
  patientId        String

  type             PatientStatus    @default(ER)
  status           AdmissionStatus  @default(ACTIVE)
  triageLevel      TriageLevel?

  chiefComplaint   String
  admittingDiagnosis String?
  finalDiagnosis   String?          // Required for PhilHealth

  // PhilHealth Case Rates
  primaryCaseRate  CaseRate?        @relation("PrimaryCaseRate", fields: [primaryCaseRateId], references: [id])
  primaryCaseRateId String?

  // Location
  roomNumber       String?
  bedNumber        String?

  // Audit
  admittedAt       DateTime         @default(now())
  dischargedAt     DateTime?
  admittedByUserId String?

  // Relations
  vitals           Vitals[]
  invoice          Invoice?
  labOrders        LabOrder[]
  nursingNotes     NursingNote[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([patientId])
  @@index([status])
}

model Medication {
  id               String           @id @default(cuid())
  code             String           @unique
  name             String
  genericName      String?
  form             String           // TABLET, SYRUP, INJECTION, etc.
  strength         String?
  unit             String           // mg, ml, etc.
  price            Decimal          @db.Decimal(12, 2)

  stock            Int              @default(0)
  reorderLevel     Int              @default(10)

  transactions     InventoryTransaction[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model InventoryTransaction {
  id               String           @id @default(cuid())
  medication       Medication       @relation(fields: [medicationId], references: [id])
  medicationId     String

  type             String           // STOCK_IN, STOCK_OUT, ADJUSTMENT, DISPENSE
  quantity         Int
  batchNumber      String?
  expiryDate       DateTime?

  referenceId      String?          // e.g., AdmissionId or PO Number

  createdAt        DateTime         @default(now())
  recordedByUserId String?
}

model LabTest {
  id               String           @id @default(cuid())
  code             String           @unique
  name             String
  category         String           // HEMATOLOGY, CLINICAL_MICROSCOPY, etc.
  price            Decimal          @db.Decimal(12, 2)

  orders           LabOrder[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime       @updatedAt
}

model LabOrder {
  id               String           @id @default(cuid())
  orderNumber      String           @unique // LAB-YYYY-XXXXX

  admission        Admission        @relation(fields: [admissionId], references: [id])
  admissionId      String

  test             LabTest          @relation(fields: [testId], references: [id])
  testId           String

  status           String           @default("PENDING") // PENDING, COLLECTED, PROCESSING, COMPLETED, CANCELLED
  result           String?          @db.Text
  orderedByUserId  String?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([admissionId])
}

model NursingNote {
  id               String           @id @default(cuid())
  admission        Admission        @relation(fields: [admissionId], references: [id])
  admissionId      String

  note             String           @db.Text
  type             String           @default("PROGRESS") // PROGRESS, SHIFT_REPORT, INCIDENT

  recordedByUserId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([admissionId])
}


model CaseRate {
  id               String           @id @default(cuid())
  code             String           @unique // ICD-10 or RVS code
  description      String
  itemType         String           // ICD or RVS
  
  hciAmount        Decimal          @db.Decimal(12, 2) // Health Care Institution portion
  hcpAmount        Decimal          @db.Decimal(12, 2) // Health Care Professional portion
  totalAmount      Decimal          @db.Decimal(12, 2)
  
  // Relations
  admissions       Admission[]      @relation("PrimaryCaseRate")
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

enum StaffRole {
  ADMIN
  DOCTOR
  NURSE
  BILLING
  PHARMACY
  LABORATORY
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  password         String         // Hashed password
  name             String
  role             StaffRole      @default(NURSE)
  
  // Relations
  staff            Staff?         @relation(fields: [staffId], references: [id])
  staffId          String?        @unique

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Department {
  id               String         @id @default(cuid())
  code             String         @unique // e.g., ER, OPD, LAB, PHAR
  name             String
  description      String?
  location         String?        // Floor, Building, etc.
  
  // Relations
  staff            Staff[]
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Staff {
  id               String         @id @default(cuid())
  staffId          String         @unique
  firstName        String
  lastName         String
  role             StaffRole      // DOCTOR, NURSE, ADMIN, BILLING
  specialization   String?
  
  // Relations
  user             User?
  department       Department?    @relation(fields: [departmentId], references: [id])
  departmentId     String?
  
  professionalFees InvoiceItem[]
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Invoice {
  id               String           @id @default(cuid())
  invoiceNumber    String           @unique // INV-YYYY-XXXXX
  
  admission        Admission        @relation(fields: [admissionId], references: [id])
  admissionId      String           @unique
  
  status           InvoiceStatus    @default(DRAFT)
  discountType     DiscountType     @default(NONE)
  
  // Totals
  grossAmount      Decimal          @default(0) @db.Decimal(12, 2)
  vatAmount        Decimal          @default(0) @db.Decimal(12, 2)
  discountAmount   Decimal          @default(0) @db.Decimal(12, 2)
  philHealthAmount Decimal          @default(0) @db.Decimal(12, 2)
  hmoAmount        Decimal          @default(0) @db.Decimal(12, 2)
  netAmount        Decimal          @default(0) @db.Decimal(12, 2)
  
  // Relations
  items            InvoiceItem[]
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([admissionId])
}

model InvoiceItem {
  id               String           @id @default(cuid())
  
  invoice          Invoice          @relation(fields: [invoiceId], references: [id])
  invoiceId        String
  
  category         String           // MEDICATION, LABORATORY, PROCEDURE, PF, ROOM
  description      String
  quantity         Int              @default(1)
  unitPrice        Decimal          @db.Decimal(12, 2)
  totalPrice       Decimal          @db.Decimal(12, 2)
  
  isVatable        Boolean          @default(true)
  
  // Professional Fees
  staff            Staff?           @relation(fields: [staffId], references: [id])
  staffId          String?
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([invoiceId])
}

model Vitals {
  id               String           @id @default(cuid())
  
  admission        Admission        @relation(fields: [admissionId], references: [id])
  admissionId      String

  // Measurements
  bpSystolic       Int?             // mmHg
  bpDiastolic      Int?             // mmHg
  temperature      Float?           // Celsius
  pulseRate        Int?             // bpm
  respiratoryRate  Int?             // breaths/min
  o2Saturation     Int?             // %
  weight           Float?           // kg
  height           Float?           // cm
  
  recordedAt       DateTime         @default(now())
  recordedByUserId String?

  @@index([admissionId])
}
